{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/admin/:path*",
      "destination": "/my-tina-app/public/admin/index.html"
    },
    {
      "source": "/tina/admin/:path*",
      "destination": "/my-tina-app/public/admin/index.html"
    },
    {
      "source": "/my-tina-app/public/admin/:path*",
      "destination": "/my-tina-app/public/admin/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}